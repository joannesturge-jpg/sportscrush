# Anthropic (for AI product standardization)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Sheets (via Apps Script web app)
# Deploy a web app from your Sheet via Extensions → Apps Script → Deploy
GOOGLE_SHEETS_SCRIPT_URL=

# Shopify
# Your store subdomain, e.g. "my-store" for my-store.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Admin API access token (from Shopify Partners or custom app)
SHOPIFY_ACCESS_TOKEN=

# eBay
# Create an app at https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
# Set to "false" for production
EBAY_SANDBOX=true

# ShipStation
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=
